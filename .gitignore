# ─────────────────────────────────────────────────────────────
#  XaiSkinLesionResearch — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Dataset & large data files ──────────────────────────────
datas/

# ── ALL results (checkpoints, plots, scores, HDF5 — too large) ─
results/

# ── Model checkpoints anywhere ───────────────────────────────
models/
*.pth
*.pt
*.ckpt
*.pkl
*.h5

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenvs/

# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~

# ── Coverage / testing ───────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ── Temp / patch files ───────────────────────────────────────
*.bak_pre_v*
/apply_patches*.py
/test_color_fix.py
/preflight_check.py
/v6/

# ── What TO track ────────────────────────────────────────────
!src/**/*.py
!*.py
!requirements*.txt
!README.md
!LICENSE
!.gitignore