# ─────────────────────────────────────────────────────────────
#  XaiSkinLesionResearch — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Dataset & large data files ──────────────────────────────
datas/
*.csv
!requirements*.txt

# ── Model checkpoints (large .pth files) ─────────────────────
models/
results/*/training/best_model.pth
results/*/abc_regressor/checkpoints/
*.pth
*.pt
*.ckpt
*.pkl

# ── Generated results (keep structure, ignore content) ───────
results/*/training/training_log.csv
results/*/evaluation/
results/*/gradcam/
results/*/lime/
results/*/counterfactual/
results/*/comparison/
results/*/abc_regressor/plots/
results/*/abc_regressor/training_log.csv
results/*/abc_regressor/evaluation_metrics.csv
results/*/ham10000_scores/
results/*/dataset/*.h5
results/*/dataset/*.csv
results/*/abc_cf/per_class/
results/*/abc_cf/ablation/
results/*/abc_cf/metrics/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenvs/

# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
desktop.ini
*~

# ── Coverage / testing ───────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ── What TO track (force-include) ────────────────────────────
# Source code always tracked:
!src/**/*.py
!*.py
# Keep result folder structure (empty dirs via .gitkeep)
!results/.gitkeep
!results/*/.gitkeep
!results/*/*/.gitkeep
